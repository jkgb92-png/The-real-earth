# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.

# ── Mapbox ────────────────────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN

# ── Cesium Ion (optional, for 3D Globe mode) ─────────────────────────────────
CESIUM_ION_TOKEN=

# ── NASA GIBS ─────────────────────────────────────────────────────────────────
GIBS_BASE_URL=https://gibs.earthdata.nasa.gov/wmts/epsg3857/best

# ── ESA Copernicus Hub ────────────────────────────────────────────────────────
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# ── Backend tile store ────────────────────────────────────────────────────────
TILE_STORE_PATH=tiles

# ── SAR-to-Optical reconstruction (disabled by default) ──────────────────────
SAR_FEATURE_ENABLED=false
SAR_MODEL_PATH=backend/sar_reconstruct/model.pt

# ── Backend CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Set to your Vercel URL in production.
CORS_ORIGINS=*

# ── Next.js web app (prefix with NEXT_PUBLIC_ for browser exposure) ───────────
NEXT_PUBLIC_TILE_SERVER_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# ── Expo mobile app (prefix with EXPO_PUBLIC_ for client exposure) ────────────
EXPO_PUBLIC_TILE_SERVER_URL=http://localhost:8000
EXPO_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN
EXPO_PUBLIC_CESIUM_ION_TOKEN=
